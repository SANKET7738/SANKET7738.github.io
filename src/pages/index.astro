  scholar_url: "https://scholar.google.com/citations?user=wV4CBqcAAAAJ&hl=en",
};
---

<Layout
  title="sanket mhatre"
  description="research fellow at microsoft research. backend engineer exploring ai research, llm fine-tuning, and ai safety."
>
  <Header nav={nav} />
  <main>
    <Hero {...heroProps} />
    <Experience {...experienceData} />
