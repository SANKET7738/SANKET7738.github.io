  },
  {
    title: "SWE-Sharp-Bench: A Reproducible Benchmark for C# Software Engineering Tasks",
    url: "https://ieeexplore.ieee.org/abstract/document/11334589",
    tag: "ieee",
    authors: "Sanket Mhatre*, Yasharth Bajpai*, Sumit Gulwani, Emerson Murphy-Hill, Gustavo Soares",
    venue: "Best Paper Award, AIWare 2025",
  },
  {
    title: "A Hybrid Method for Fake News Detection using Cosine Similarity Scores",
    url: "https://ieeexplore.ieee.org/abstract/document/9510134",
    tag: "ieee",
    authors: "S. Mhatre, A. Masurkar",
    venue: "ICCICT 2021",
  },
];

const footerContent = {
  id: "contact",
  status: "open to research collaborations",
  email_label: "email",
  email_url: "mailto:sanketmhatre7738@gmail.com",
  github_label: "github",
  github_url: "https://github.com/SANKET7738",
  linkedin_label: "linkedin",
  linkedin_url: "https://linkedin.com/in/sanket-mhatre-782a081a6",
